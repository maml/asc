{
  "name": "asc",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "workspaces": [
    "packages/*"
  ],
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "start": "node dist/server.js",
    "build:client": "cd packages/client && tsc",
    "build:mcp": "cd packages/mcp-server && tsc",
    "start:mcp": "node packages/mcp-server/dist/index.js",
    "test:client": "cd packages/client && vitest run",
    "test:mcp": "cd packages/mcp-server && vitest run",
    "dev": "tsx src/server.ts",
    "agents": "tsx src/simulated/start-agents.ts",
    "migrate": "tsx src/db/migrate.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "demo:docs": "tsx demos/doc-processing/run.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run '.unit.test.ts'",
    "test:repo": "vitest run '.repo.test.ts'",
    "test:api": "vitest run '.api.test.ts'",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "changeset publish",
    "seed:sandbox": "tsx scripts/sandbox-seed.ts"
  },
  "keywords": [],
  "author": "",
  "license": "FSL-1.1-MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "type": "module",
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@types/pg": "^8.16.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/websocket": "^11.2.0",
    "@noble/curves": "^2.0.1",
    "@noble/hashes": "^2.0.1",
    "@noble/secp256k1": "^3.0.0",
    "fastify": "^5.7.4",
    "pg": "^8.18.0"
  }
}
