# ASC Environment Variables
# Copy to .env and fill in values

# === Database ===
# Option 1: Connection string (Neon / production)
# DATABASE_URL=postgres://user:pass@host/dbname?sslmode=require

# Option 2: Individual fields (local dev)
DB_HOST=localhost
DB_PORT=5433
DB_NAME=asc
DB_USER=asc
DB_PASSWORD=asc_dev_password

# === Server ===
PORT=3100
NODE_ENV=development

# === CORS ===
# Comma-separated origins for production (omit for permissive dev mode)
# CORS_ORIGIN=https://asc.example.com,https://preview.asc.example.com

# === Settlement (optional) ===
# Phoenixd (self-hosted Lightning node — preferred)
# PHOENIXD_PASSWORD=your_phoenixd_api_password
# PHOENIXD_URL=http://localhost:9740

# Strike (custodial Lightning — fallback)
# STRIKE_API_KEY=your_strike_api_key

# === Preview Environment ===
# For preview deployments (NODE_ENV=preview):
# DATABASE_URL=postgres://user:pass@preview-host/dbname?sslmode=require
# PHOENIXD_URL=http://137.184.90.12:9741
# PHOENIXD_PASSWORD=your_phoenixd_testnet_password
# CORS_ORIGIN=https://preview.asc.so
